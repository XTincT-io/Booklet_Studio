# Database — matches docker-compose.yml's Postgres credentials
DATABASE_URL="postgresql://booklet:booklet@localhost:5432/booklet_studio"

# NextAuth — REQUIRED. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-string"
NEXTAUTH_URL="http://localhost:3000"

# App
APP_URL="http://localhost:3000"

# Asset storage (S3-compatible) — required only for image/audio upload
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
ASSET_BUCKET="booklet-studio-assets"
ASSET_PUBLIC_BASE_URL="https://booklet-studio-assets.s3.amazonaws.com"

# Stripe — required only for self-serve tier upgrades (dev/set-tier route works without these)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_INDIE_ARTIST=""
STRIPE_PRICE_INDIE_LABEL=""
